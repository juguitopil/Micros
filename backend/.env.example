# Copia este archivo a .env y rellená los valores reales
# Nunca subas el .env real a GitHub — solo este .env.example

# Puerto donde corre el servidor (Render usa el que él asigne, no el tuyo)
PORT=3001

# URL de conexión a PostgreSQL
# Formato: postgres://usuario:contraseña@host:5432/nombre_db
DATABASE_URL=postgres://usuario:contraseña@localhost:5432/micros_db

# Origen permitido para CORS (la URL de tu frontend en Vercel)
# En local usás http://localhost:3000
FRONTEND_URL=http://localhost:3000
